            this.Controls.Add(new Label { Text = "Hostel Name:", Location = new Point(left, top), Size = new Size(labelWidth, 20) });
            txtName = new TextBox { Location = new Point(left + labelWidth, top - 3), Size = new Size(controlWidth, 22) };
