using System;
using System.Drawing;
using System.Linq;
using System.Windows.Forms;
using HostelFinderPrototype;

namespace HOSTEL_FINDER_PROTOTYPE_GROUP_5
{
    // Programmatic (non-designer) ManagerDashboard to avoid designer conflicts.
    public class ManagerDashboard : Form
    {
        private TextBox txtName;
        private TextBox txtLocation;
        private TextBox txtPrice;
        private TextBox txtCondition;
        private TextBox txtAvailableRooms;
        private TextBox txtManagerContact;
        private Button btnSave;
        private Button btnUpdate;
        private Button btnDelete;
        private Button btnNew;
        private DataGridView dgvHostels;
        private int selectedIndex = -1; // tracks selected hostel in the listbox

        public ManagerDashboard()
        {
            this.Text = "Manager Dashboard";
            this.StartPosition = FormStartPosition.CenterScreen;
            this.Size = new Size(900, 560);
            InitializeControls();

            // Ensure some seed hostels exist (only add if absent)
            EnsureInitialHostels();

            RefreshHostelList();
        }

        // selection handling moved to the DataGridView selection changed handler

        private void BtnNew_Click(object sender, EventArgs e)
        {
            dgvHostels.ClearSelection();
            selectedIndex = -1;
            ClearInputs();
            btnUpdate.Enabled = false;
            btnDelete.Enabled = false;
            btnSave.Enabled = true;
        }

        private void BtnUpdate_Click(object sender, EventArgs e)
        {
            if (selectedIndex < 0 || selectedIndex >= DataStore.Hostels.Count)
            {
                MessageBox.Show("No hostel selected to update.", "Error", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            // Reuse validation from save
            if (string.IsNullOrWhiteSpace(txtName.Text) ||
                string.IsNullOrWhiteSpace(txtLocation.Text) ||
                string.IsNullOrWhiteSpace(txtPrice.Text) ||
                string.IsNullOrWhiteSpace(txtCondition.Text) ||
                string.IsNullOrWhiteSpace(txtAvailableRooms.Text))
            {
                MessageBox.Show("Please fill in all fields.", "Validation", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            if (!decimal.TryParse(txtPrice.Text, out decimal price))
            {
                MessageBox.Show("Enter a valid price.", "Validation", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            if (!int.TryParse(txtAvailableRooms.Text, out int available))
            {
                MessageBox.Show("Enter a valid number for available rooms.", "Validation", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            var hostel = DataStore.Hostels[selectedIndex];
            hostel.Name = txtName.Text.Trim();
            hostel.Location = txtLocation.Text.Trim();
            hostel.Price = price;
            hostel.Condition = txtCondition.Text.Trim();
            hostel.AvailableRooms = available;
            hostel.ManagerContact = txtManagerContact.Text.Trim();

            MessageBox.Show("Hostel updated.", "Success", MessageBoxButtons.OK, MessageBoxIcon.Information);
            RefreshHostelList();
            // keep selection in grid
            if (selectedIndex >= 0 && selectedIndex < dgvHostels.Rows.Count)
            {
                dgvHostels.ClearSelection();
                dgvHostels.Rows[selectedIndex].Selected = true;
            }
        }

        private void BtnDelete_Click(object sender, EventArgs e)
        {
            if (selectedIndex < 0 || selectedIndex >= DataStore.Hostels.Count)
            {
                MessageBox.Show("No hostel selected to delete.", "Error", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            var confirm = MessageBox.Show("Are you sure you want to delete the selected hostel?", "Confirm Delete", MessageBoxButtons.YesNo, MessageBoxIcon.Question);
            if (confirm != DialogResult.Yes) return;

            DataStore.Hostels.RemoveAt(selectedIndex);
            MessageBox.Show("Hostel deleted.", "Success", MessageBoxButtons.OK, MessageBoxIcon.Information);
            selectedIndex = -1;
            ClearInputs();
            RefreshHostelList();
            btnUpdate.Enabled = false;
            btnDelete.Enabled = false;
            btnSave.Enabled = true;
        }

