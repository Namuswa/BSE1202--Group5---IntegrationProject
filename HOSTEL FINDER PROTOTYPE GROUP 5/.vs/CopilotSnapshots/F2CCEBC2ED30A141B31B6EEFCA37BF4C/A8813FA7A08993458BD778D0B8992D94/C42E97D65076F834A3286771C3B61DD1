            txtLocation = new TextBox { Location = new Point(left + labelWidth, top - 3), Size = new Size(controlWidth, 22) };
            this.Controls.Add(txtLocation);

            top += spacing;
            this.Controls.Add(new Label { Text = "Price:", Location = new Point(left, top), Size = new Size(labelWidth, 20) });
            txtPrice = new TextBox { Location = new Point(left + labelWidth, top - 3), Size = new Size(controlWidth, 22) };
            this.Controls.Add(txtPrice);

            top += spacing;
            this.Controls.Add(new Label { Text = "Condition:", Location = new Point(left, top), Size = new Size(labelWidth, 20) });
            txtCondition = new TextBox { Location = new Point(left + labelWidth, top - 3), Size = new Size(controlWidth, 22) };
            this.Controls.Add(txtCondition);

            top += spacing;
            this.Controls.Add(new Label { Text = "Available Rooms:", Location = new Point(left, top), Size = new Size(labelWidth, 20) });
