                AllowUserToAddRows = false,
                AllowUserToDeleteRows = false,
                SelectionMode = DataGridViewSelectionMode.FullRowSelect,
                MultiSelect = false,
                AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill
            };

            dgvHostels.Columns.Add("Name", "Hostel Name");
            dgvHostels.Columns.Add("Location", "Location");
            dgvHostels.Columns.Add("Price", "Price");
            dgvHostels.Columns.Add("Condition", "Condition");
            dgvHostels.Columns.Add("AvailableRooms", "Available Rooms");
            dgvHostels.Columns.Add("Rating", "Rating");

            dgvHostels.SelectionChanged += DgvHostels_SelectionChanged;
            this.Controls.Add(dgvHostels);

            var lblList = new Label { Text = "Existing Hostels:", Location = new Point(360, 15), AutoSize = true, Font = new Font(FontFamily.GenericSansSerif, 10, FontStyle.Bold) };
            this.Controls.Add(lblList);
        }

        private void BtnSave_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrWhiteSpace(txtName.Text) ||
                string.IsNullOrWhiteSpace(txtLocation.Text) ||
                string.IsNullOrWhiteSpace(txtPrice.Text) ||
                string.IsNullOrWhiteSpace(txtCondition.Text) ||
                string.IsNullOrWhiteSpace(txtAvailableRooms.Text))
            {
                MessageBox.Show("Please fill in all fields.", "Validation", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            if (!decimal.TryParse(txtPrice.Text, out decimal price))
            {
                MessageBox.Show("Enter a valid price.", "Validation", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            if (!int.TryParse(txtAvailableRooms.Text, out int available))
            {
                MessageBox.Show("Enter a valid number for available rooms.", "Validation", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            var hostel = new Hostel
            {
                Name = txtName.Text.Trim(),
                Location = txtLocation.Text.Trim(),
                Price = price,
                Condition = txtCondition.Text.Trim(),
                AvailableRooms = available,
                UnavailableRooms = 0,
                Rating = 0,
                ManagerContact = txtManagerContact.Text.Trim()
            };

            DataStore.Hostels.Add(hostel);
            MessageBox.Show("Hostel saved.", "Success", MessageBoxButtons.OK, MessageBoxIcon.Information);
            // Notify subscribers (e.g., student dashboard) that hostels changed
            DataStore.NotifyHostelsChanged();
            ClearInputs();
            RefreshHostelList();
        }

        private void ClearInputs()
        {
            txtName.Text = "";
            txtLocation.Text = "";
            txtPrice.Text = "";
            txtCondition.Text = "";
            txtAvailableRooms.Text = "";
            txtManagerContact.Text = "";
        }

        private void RefreshHostelList()
        {
            dgvHostels.Rows.Clear();
            foreach (var h in DataStore.Hostels)
            {
                dgvHostels.Rows.Add(h.Name, h.Location, h.Price.ToString("C"), h.Condition, h.AvailableRooms, h.Rating);
            }
        }

        private void DgvHostels_SelectionChanged(object sender, EventArgs e)
        {
            if (dgvHostels.SelectedRows.Count == 0)
            {
                selectedIndex = -1;
                btnUpdate.Enabled = false;
                btnDelete.Enabled = false;
                btnSave.Enabled = true;
                return;
            }

            selectedIndex = dgvHostels.SelectedRows[0].Index;
            if (selectedIndex < 0 || selectedIndex >= DataStore.Hostels.Count) return;

            var h = DataStore.Hostels[selectedIndex];
            txtName.Text = h.Name;
            txtLocation.Text = h.Location;
            txtPrice.Text = h.Price.ToString();
            txtCondition.Text = h.Condition;
            txtAvailableRooms.Text = h.AvailableRooms.ToString();
            txtManagerContact.Text = h.ManagerContact;

            btnUpdate.Enabled = true;
            btnDelete.Enabled = true;
            btnSave.Enabled = false;
        }

        private void EnsureInitialHostels()
        {
            // Add the two hostels the user specified if they don't exist
            if (!DataStore.Hostels.Any(h => h.Name.Equals("Joy Hostel", StringComparison.OrdinalIgnoreCase)))
            {
                DataStore.Hostels.Add(new Hostel { Name = "Joy Hostel", Location = "Hill Side", Price = 1200000m, AvailableRooms = 10, UnavailableRooms = 0, Rating = 4.2, Condition = "Good", ManagerContact = "0771000001" });
            }

            if (!DataStore.Hostels.Any(h => h.Name.Equals("Pimez Hostel", StringComparison.OrdinalIgnoreCase)))
            {
                DataStore.Hostels.Add(new Hostel { Name = "Pimez Hostel", Location = "Palm Ville", Price = 990000m, AvailableRooms = 8, UnavailableRooms = 0, Rating = 4.0, Condition = "Good", ManagerContact = "0771000002" });
            }

            // Generate 5 additional hostels automatically if not present
            var generated = new[] {
                new Hostel { Name = "Sunrise Lodge", Location = "East End", Price = 750000m, AvailableRooms = 6, UnavailableRooms = 0, Rating = 3.8, Condition = "Fair", ManagerContact = "0771000003" },
                new Hostel { Name = "Green Garden", Location = "West Park", Price = 680000m, AvailableRooms = 12, UnavailableRooms = 0, Rating = 4.1, Condition = "Good", ManagerContact = "0771000004" },
                new Hostel { Name = "Lakeview Suites", Location = "Lakeside", Price = 1500000m, AvailableRooms = 4, UnavailableRooms = 0, Rating = 4.6, Condition = "Excellent", ManagerContact = "0771000005" },
                new Hostel { Name = "Maple Residency", Location = "Old Town", Price = 540000m, AvailableRooms = 20, UnavailableRooms = 0, Rating = 3.9, Condition = "Good", ManagerContact = "0771000006" },
                new Hostel { Name = "Bright Homes", Location = "Central", Price = 880000m, AvailableRooms = 9, UnavailableRooms = 0, Rating = 4.0, Condition = "Good", ManagerContact = "0771000007" }
            };

            foreach (var g in generated)
            {
                if (!DataStore.Hostels.Any(h => h.Name.Equals(g.Name, StringComparison.OrdinalIgnoreCase)))
                {
                    DataStore.Hostels.Add(g);
                }
            }
        }

