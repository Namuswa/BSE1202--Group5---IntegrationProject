using System;
using System.Drawing;
using System.Linq;
using System.Windows.Forms;
using HostelFinderPrototype;

namespace HOSTEL_FINDER_PROTOTYPE_GROUP_5
{
    public class AdminDashboard : Form
    {
        private DataGridView dgvUsers;
        private Button btnBack;
        public AdminDashboard()
        {            };            dgvUsers.Columns.Add("Name", "Name");            dgvUsers.Columns.Add("Email", "Email");            dgvUsers.Columns.Add("Role", "Role");            dgvUsers.Columns.Add("RegistrationTime", "Registered At");            this.Controls.Add(dgvUsers);            btnBack = new Button { Text = "Back to Login", Location = new Point(20, 420), Size = new Size(120, 30) };            btnBack.Click += BtnBack_Click;            this.Controls.Add(btnBack);        }        private void BtnBack_Click(object sender, EventArgs e)        {            var login = Application.OpenForms.OfType<LoginForm>().FirstOrDefault();            if (login != null)            {                login.Show();            }            else            {                var newLogin = new LoginForm();                newLogin.Show();            }            this.Hide();        }        private void RefreshUserList()        {            dgvUsers.Rows.Clear();            foreach (var u in DataStore.Users)            {                string regTime = "-";                var prop = u.GetType().GetProperty("RegistrationTime");                if (prop != null)                {                    var val = prop.GetValue(u);                    if (val != null)                    {                        // format if DateTime                        if (val is DateTime dt && dt > DateTime.MinValue)                            regTime = dt.ToString("g");                        else                            regTime = val.ToString();                    }                }                dgvUsers.Rows.Add(u.Name, u.Email, u.Role, regTime);            }        }    }}
